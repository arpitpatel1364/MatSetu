# App Configuration
APP_NAME=MatSetu
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=CHANGE_ME_IN_PRODUCTION
BOOTH_SECRET=CHANGE_ME_BOOTH_SECRET

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://matsetu:matsetu_secure_password@postgres:5432/matsetu
DATABASE_URL_SYNC=postgresql://matsetu:matsetu_secure_password@postgres:5432/matsetu
POSTGRES_DB=matsetu
POSTGRES_USER=matsetu
POSTGRES_PASSWORD=matsetu_secure_password

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant (Vector DB)
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# MinIO (S3 Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_SECURE=False

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Monitoring (Grafana/Prometheus)
GF_SECURITY_ADMIN_PASSWORD=matsetu_grafana

# Optional: SMS Providers
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MSG91_AUTH_KEY=
